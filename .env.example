# Copy to .env.local and fill from `supabase status` after `supabase start`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Optional Firebase / FCM (push notifications). In-app notifications work without these.
# FIREBASE_API_KEY=
# FIREBASE_APP_ID=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_VAPID_KEY=
